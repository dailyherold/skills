@article{1,
  author    = {Cepeda, Nicholas J. and Pashler, Harold and Vul, Edward and
               Wixted, John T. and Rohrer, Doug},
  title     = {Distributed Practice in Verbal Recall Tasks: A Review and
               Quantitative Synthesis},
  journal   = {Psychological Bulletin},
  volume    = {132},
  number    = {3},
  pages     = {354--380},
  year      = {2006},
  doi       = {10.1037/0033-2909.132.3.354},
  note      = {Optimal inter-study intervals scale to ~10-20% of the desired
               retention period. The steepest forgetting happens in the first
               48 hours — weekly review alone misses this critical window.
               Foundational precursors: Ebbinghaus (1885) forgetting curve;
               Wozniak SM-2 algorithm (used in Anki).}
}

@incollection{2,
  author    = {Bjork, Robert A. and Bjork, Elizabeth L.},
  title     = {A New Theory of Disuse and an Old Theory of Stimulus Fluctuation},
  booktitle = {From Learning Processes to Cognitive Processes: Essays in Honor
               of William K. Estes},
  editor    = {Healy, Alice F. and Kosslyn, Stephen M.},
  volume    = {2},
  pages     = {35--67},
  publisher = {Lawrence Erlbaum Associates},
  year      = {1992},
  note      = {Conditions that make learning harder in specific ways —
               interleaving, spacing, generation, varied practice — improve
               long-term retention even though they slow initial performance.
               See also: Rohrer, D. and Taylor, K. (2007), European Journal of
               Cognitive Psychology 19(4-5); Kornell, N. and Bjork, R.A.
               (2008), Psychological Science 19(6).}
}

@book{3,
  author    = {Papert, Seymour},
  title     = {Mindstorms: Children, Computers, and Powerful Ideas},
  publisher = {MIT Press},
  year      = {1980},
  isbn      = {978-0465046270},
  note      = {People learn most effectively when constructing external,
               shareable artifacts. The artifact externalizes cognition, makes
               misconceptions visible, and creates feedback loops.
               See also: Resnick, M. (2017), Lifelong Kindergarten, MIT Press.}
}

@book{4,
  author    = {Anderson, Lorin W. and Krathwohl, David R.},
  title     = {A Taxonomy for Learning, Teaching, and Assessing: A Revision
               of Bloom's Taxonomy of Educational Objectives},
  publisher = {Longman},
  year      = {2001},
  isbn      = {978-0801319037},
  note      = {Revised hierarchy: Remember, Understand, Apply, Analyze, Evaluate,
               Create. Most learning stalls at Understand — deliberately push
               higher. Key revision from original Bloom (1956): swapped top two
               levels (Create above Evaluate), changed nouns to verbs.}
}

@article{5,
  author    = {Ericsson, K. Anders and Krampe, Ralf Th. and Tesch-R{\"o}mer, Clemens},
  title     = {The Role of Deliberate Practice in the Acquisition of Expert Performance},
  journal   = {Psychological Review},
  volume    = {100},
  number    = {3},
  pages     = {363--406},
  year      = {1993},
  doi       = {10.1037/0033-295X.100.3.363},
  note      = {Expertise comes from practice that targets specific weaknesses with
               immediate feedback — not from accumulated hours. After each phase,
               identify the 2 weakest sub-skills and drill those specifically.
               See also: Ericsson, K.A. and Pool, R. (2016), Peak,
               Houghton Mifflin Harcourt.}
}

@incollection{6,
  author    = {Perkins, David N. and Salomon, Gavriel},
  title     = {Transfer of Learning},
  booktitle = {International Encyclopedia of Education},
  editor    = {Husén, Torsten and Postlethwaite, T. Neville},
  edition   = {2},
  publisher = {Pergamon Press},
  year      = {1992},
  note      = {Far transfer is rare without deliberate bridging through explicit
               structural analogies. Abstract principles transfer better than
               concrete procedures. See also: Barnett, S.M. and Ceci, S.J.
               (2002), Psychological Bulletin 128(4), 612-637 — taxonomy of
               transfer distance.}
}

@book{7,
  author    = {Paivio, Allan},
  title     = {Mental Representations: A Dual Coding Approach},
  publisher = {Oxford University Press},
  year      = {1986},
  isbn      = {978-0195039368},
  note      = {Encoding information in both verbal and visual channels creates
               redundant memory traces and strengthens recall for everyone —
               not matched to individual learning styles (debunked: Pashler
               et al. 2008, Psychological Science in the Public Interest 9(3)).
               See also: Mayer, R.E. (2001/2020), Multimedia Learning (3rd ed.),
               Cambridge University Press.}
}

@article{8,
  author    = {Slamecka, Norman J. and Graf, Peter},
  title     = {The Generation Effect: Delineation of a Phenomenon},
  journal   = {Journal of Experimental Psychology: Human Learning and Memory},
  volume    = {4},
  number    = {6},
  pages     = {592--604},
  year      = {1978},
  doi       = {10.1037/0278-7393.4.6.592},
  note      = {Self-generated answers create stronger memory traces than read
               answers — even with equal study time. Protege effect: preparing
               to teach forces gap-identification; knowledge-building (elaborating,
               connecting) benefits the teacher; knowledge-telling (stating facts)
               does not. See also: Roediger, H.L. and Karpicke, J.D. (2006),
               Psychological Science 17(3); Fiorella, L. and Mayer, R.E. (2013),
               Contemporary Educational Psychology 38(4); Roscoe, R.D. and
               Chi, M.T.H. (2007), Review of Educational Research 77(4).}
}

@techreport{9,
  author      = {Bastani, Hamsa and Bastani, Osbert and Sungu, Alp},
  title       = {Generative AI Can Harm Learning},
  institution = {Wharton School, University of Pennsylvania},
  type        = {Working Paper},
  year        = {2024},
  url         = {https://papers.ssrn.com/sol3/papers.cfm?abstract_id=4895486},
  note        = {Students with unrestricted GPT-4 access performed worse than
               controls. Students with Socratic-constrained AI outperformed both
               groups. Cognitive offloading is the mechanism — AI generates the
               thinking, learner gets the illusion of understanding without
               the memory trace. See also: Mollick, E.R. and Mollick, L. (2023),
               Wharton working paper on AI teaching strategies; Bloom, B.S.
               (1984), Educational Researcher 13(6) — the 2 sigma problem.}
}

@article{10,
  author    = {Lamport, Leslie},
  title     = {State the Problem Before Describing the Solution},
  journal   = {ACM SIGSOFT Software Engineering Notes},
  volume    = {3},
  number    = {1},
  pages     = {26--26},
  year      = {1978},
  doi       = {10.1145/1010734.1010737},
  note      = {Correctness conditions must be stated explicitly before evaluating
               solutions. Without them, solution comparison is intuitive rather
               than objective — and scope discipline becomes impossible to enforce.}
}
